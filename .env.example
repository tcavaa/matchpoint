# Supabase project credentials (copy from Project Settings → API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Admin panel password — protects /admin/* routes in the browser
VITE_ADMIN_PASSWORD=changeme

# Displayed on the public customer booking page
VITE_VENUE_NAME=MatchPoint

# Flitt payment gateway — set these as secrets in the Supabase dashboard
# (supabase secrets set FLITT_MERCHANT_ID=... FLITT_SECRET_KEY=...)
# Do NOT prefix with VITE_ — these must stay server-side only
FLITT_MERCHANT_ID=<your-merchant-id>
FLITT_SECRET_KEY=<your-secret-key>
